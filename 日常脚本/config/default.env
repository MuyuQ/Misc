# default.env — 监控脚本全局默认配置
# 环境变量可覆盖此处定义的值

# === 邮件告警 ===
# MAIL_TO="admin@example.com"
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER="user"
# SMTP_PASS="pass"

# === 系统与资源 ===
# CPU_LOAD_WARN=4.0
# CPU_LOAD_CRIT=8.0
# CPU_STEAL_WARN=5
# CPU_STEAL_CRIT=10
# MEM_WARN_PERCENT=80
# MEM_CRIT_PERCENT=90
# DISK_WARN_PERCENT=80
# DISK_CRIT_PERCENT=90
# INODE_WARN_PERCENT=80
# INODE_CRIT_PERCENT=90
# ENTROPY_WARN=512
# ENTROPY_CRIT=256
# PSI_WARN=0.5
# PSI_CRIT=0.8

# === 网络 ===
# PING_TARGETS="1.1.1.1,8.8.8.8"
# PING_LOSS_WARN_PERCENT=20
# PING_LOSS_CRIT_PERCENT=50
# TLS_CHECK_TARGETS="example.com:443"
# TLS_EXPIRY_WARN_DAYS=21
# TLS_EXPIRY_CRIT_DAYS=7
# BANDWIDTH_WARN_BPS=12500000
# BPS_CRIT=62500000

# === HTTP ===
# HTTP_CHECK_URLS="https://example.com/"

# === 服务 ===
# REQUIRED_SERVICES="sshd"

# === 备份 ===
# BACKUP_MARKERS="/var/log/backup.ok"
# BACKUP_MAX_AGE_HOURS=24

# === MySQL ===
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASS=
# MYSQL_CONN_WARN=200
# MYSQL_CONN_CRIT=400

# === PostgreSQL ===
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=
# PG_CONN_WARN=200
# PG_CONN_CRIT=400

# === Redis ===
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_MEM_WARN_MB=1024
# REDIS_MEM_CRIT_MB=2048

# === 安全扫描 ===
# SCAN_PATHS="/etc,/opt,/var/www"
# EXPECTED_USERS=""
